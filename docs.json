{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Mint Starter Kit",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Download PDF (EN)",
          "icon": "file-pdf",
          "href": "/help-center-en.pdf"
        },
        {
          "anchor": "PDF herunterladen (DE)",
          "icon": "file-pdf",
          "href": "/help-center-de.pdf"
        }
      ]
    },
    "languages": [
      {
        "language": "en",
        "default": true,
        "groups": [
          {
            "group": "Articles",
            "pages": [
              "en/creating-articles",
              "en/editing-articles",
              "en/deleting-restoring-articles",
              "en/table"
            ]
          },
          {
            "group": "Orders & Stock",
            "pages": [
              "en/managing-orders",
              "en/minimum-stock-order-proposals",
              "en/conducting-stocktaking"
            ]
          },
          {
            "group": "Customers",
            "pages": [
              "en/digital-customer-registration",
              "en/pos-registration-completion"
            ]
          },
          {
            "group": "Commerce",
            "pages": [
              "en/managing-discounts",
              "en/managing-gift-cards",
              "en/managing-seasons-collections"
            ]
          },
          {
            "group": "Administration",
            "pages": [
              "en/configuring-suppliers-brands",
              "en/managing-users",
              "en/setting-up-shifts"
            ]
          },
          {
            "group": "Settings",
            "pages": [
              "en/currency-settings",
              "en/receipt-settings",
              "en/activating-qr-invoices"
            ]
          }
        ]
      },
      {
        "language": "de",
        "groups": [
          {
            "group": "Artikel",
            "pages": [
              "de/creating-articles",
              "de/editing-articles",
              "de/deleting-restoring-articles"
            ]
          },
          {
            "group": "Aufträge & Bestand",
            "pages": [
              "de/managing-orders",
              "de/minimum-stock-order-proposals",
              "de/conducting-stocktaking"
            ]
          },
          {
            "group": "Kunden",
            "pages": [
              "de/digital-customer-registration",
              "de/pos-registration-completion"
            ]
          },
          {
            "group": "Verkauf",
            "pages": [
              "de/managing-discounts",
              "de/managing-gift-cards",
              "de/managing-seasons-collections"
            ]
          },
          {
            "group": "Verwaltung",
            "pages": [
              "de/configuring-suppliers-brands",
              "de/managing-users",
              "de/setting-up-shifts"
            ]
          },
          {
            "group": "Einstellungen",
            "pages": [
              "de/currency-settings",
              "de/receipt-settings",
              "de/activating-qr-invoices"
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:hi@mintlify.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.mintlify.com"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/mintlify",
      "github": "https://github.com/mintlify",
      "linkedin": "https://linkedin.com/company/mintlify"
    }
  }
